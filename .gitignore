# ── Keep .env.example (safe template, no real values) ─────────
!.env.example
!ias3-hunt/.env.example

# ── OS & editor noise ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ── Debug & logs ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Playwright test artifacts ─────────────────────────────────
.playwright-mcp/
playwright-report/
test-results/

# ── Screenshot dumps (dev only) ───────────────────────────────
*.png
!public/**/*.png
!ias3-hunt/public/**/*.png

